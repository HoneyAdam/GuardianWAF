# Auto detect text files and normalize line endings
* text=auto

# Go files
*.go text eol=lf

# Shell scripts
*.sh text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Markdown
*.md text eol=lf

# Web assets
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Docker
Dockerfile text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
